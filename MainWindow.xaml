<Window x:Class="WebDavEncryptManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WebDAV 加密管理" Height="650" Width="1000" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate x:Key="FileTemplate">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Icon}" Grid.Column="0"/>
                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" Grid.Column="1"/>
                <TextBlock Text="{Binding DisplaySize}" Foreground="Gray" HorizontalAlignment="Right" Grid.Column="2"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 顶部栏 -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="💻 本地磁盘" FontWeight="Bold" Margin="0,0,10,0"/>
                <ComboBox x:Name="ComboDrives" Width="60" SelectionChanged="ComboDrives_SelectionChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="信封密钥:" Margin="0,0,5,0" Foreground="Gray" VerticalAlignment="Center"/>

                <!-- 使用 Grid 将明文框和密文框叠在一起 -->
                <Grid Width="120" Margin="0,0,10,0">
                    <TextBox x:Name="TxtCustomKeyVisible" Height="25" Padding="2" Visibility="Visible" ToolTip="在此输入自定义密钥"/>
                    <PasswordBox x:Name="TxtCustomKeyHidden" Height="25" Padding="2" Visibility="Collapsed" IsEnabled="False"/>
                </Grid>

                <!-- 新增的确定/修改按钮 -->
                <Button x:Name="BtnConfirmKey" Content="确定" Height="25" Padding="15,0" Margin="0,0,15,0" Click="BtnConfirmKey_Click"/>

                <Button Content="⚙️ WebDAV 设置" Height="30" Padding="10,0" Click="BtnSettings_Click"/>
            </StackPanel>
        </Grid>

        <!-- 双栏列表 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                <ListBox x:Name="ListLocal" SelectionMode="Extended" BorderThickness="0" ItemTemplate="{StaticResource FileTemplate}" MouseDoubleClick="ListLocal_MouseDoubleClick">
                    <!-- 左侧本地列表的右键菜单 -->
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="打开" Click="MenuLocalOpen_Click"/>
                            <MenuItem Header="加密上传至云端" Click="MenuLocalUpload_Click" FontWeight="Bold"/>
                            <Separator/>
                            <MenuItem Header="删除 (回收站)" Click="MenuLocalDelete_Click"/>
                            <MenuItem Header="重命名" Click="MenuLocalRename_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" Background="#EEE"/>

            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TxtRemotePath" Text="☁️ 云端路径: /" FontWeight="Bold" Margin="5"/>
                    <ListBox x:Name="ListRemote" Grid.Row="1" SelectionMode="Extended" BorderThickness="0" ItemTemplate="{StaticResource FileTemplate}" MouseDoubleClick="ListRemote_MouseDoubleClick">
                        <!-- 右侧云端列表的右键菜单 -->
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="打开 / 播放" Click="MenuRemoteOpen_Click"/>
                                <MenuItem Header="解密下载到本地" Click="MenuRemoteDownload_Click" FontWeight="Bold"/>
                                <Separator/>
                                <MenuItem Header="重命名" Click="MenuRemoteRename_Click"/>
                                <MenuItem Header="移动到..." Click="MenuRemoteMove_Click"/>
                                <Separator/>
                                <MenuItem Header="彻底删除" Click="MenuRemoteDelete_Click" Foreground="Red"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部进度栏 -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="⬆️ 加密上传" Width="120" Height="35" Margin="0,0,10,0" Click="BtnUpload_Click" Background="#0078D7" Foreground="White" FontWeight="Bold"/>

            <Grid Grid.Column="1">
                <!-- 去掉了无限循环，设置了最大最小值 -->
                <ProgressBar x:Name="PrgTask" Height="35" Minimum="0" Maximum="100"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtStatus" Text="就绪" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtPercentage" Text="" FontWeight="Bold" Foreground="#333"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>