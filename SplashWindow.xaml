<Window x:Class="WebDavEncryptManager.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="启动与免责声明" Height="480" Width="550" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <Window.Resources>
        <Style x:Key="AcceptBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RejectBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="White" BorderBrush="#DDDDDD" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="WebDAV 加密云同步系统" FontSize="22" FontWeight="Bold" Foreground="#333"/>
                <Border Height="2" Background="#007ACC" Width="40" HorizontalAlignment="Left" Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#F9F9F9" CornerRadius="6" Padding="15" Margin="0,5,0,20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="【免责声明与使用协议】" FontWeight="Bold" Margin="0,0,0,10" Foreground="#D32F2F"/>

                        <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="#555" FontSize="13">
                            1. <Run FontWeight="Bold" Foreground="#333">法律用途：</Run>本软件仅供个人安全备份及技术研究使用。严禁将其用于任何违反法律法规、传播非法内容或侵害他人隐私的行为。<LineBreak/><LineBreak/>
                            2. <Run FontWeight="Bold" Foreground="#333">禁止牟利：</Run>本软件为免费/内部工具，严禁任何形式的二次打包、倒卖、租用或用于商业分发。一经发现，作者保留追究权利。<LineBreak/><LineBreak/>
                            3. <Run FontWeight="Bold" Foreground="#333">风险自担：</Run>加密存储具有不可逆性，请务必妥善保管您的“信封密钥”。作者不对因软件缺陷、误操作、密钥丢失或不可抗力导致的数据损坏、丢失承担任何赔偿责任。<LineBreak/><LineBreak/>
                            4. <Run FontWeight="Bold" Foreground="#333">最终解释权：</Run>点击“同意并继续”即视为您已完全理解并接受上述所有条款。若您不同意，请点击“拒绝并退出”。
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2">

                <StackPanel x:Name="ActionPanel" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Visible">
                    <Button Content="拒绝并退出" Style="{StaticResource RejectBtnStyle}" Margin="0,0,15,0" Click="BtnReject_Click"/>
                    <Button Content="✅ 同意并继续" Style="{StaticResource AcceptBtnStyle}" Click="BtnAccept_Click"/>
                </StackPanel>

                <StackPanel x:Name="LoadingPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <ProgressBar x:Name="PrgBar" Height="6" IsIndeterminate="True" Foreground="#007ACC" Background="#EEE" BorderThickness="0" Margin="0,0,0,10"/>
                    <Grid>
                        <TextBlock x:Name="TxtStatus" Text="等待操作..." Foreground="#999" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="V1.0.0 Pro" Foreground="#CCC" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>