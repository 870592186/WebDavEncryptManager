<Window x:Class="WebDavEncryptManager.SyncDriveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WebDavEncryptManager"
        Title="加密同步盘" Height="650" Width="1000" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:BoolToFolderIconConverter x:Key="BoolToFolderIconConverter"/>

        <DataTemplate x:Key="SyncFileTemplate">
            <Border BorderBrush="#DDD" BorderThickness="1" Margin="2,2,2,0" CornerRadius="3" ClipToBounds="True">
                <Grid>
                    <Grid.Background>
                        <SolidColorBrush Color="#FFF0F0" />
                    </Grid.Background>

                    <ProgressBar Value="{Binding Percentage}" Minimum="0" Maximum="100" 
                                 Background="Transparent" Foreground="#81C784" BorderThickness="0" 
                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                    <Grid Margin="8,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding IsDirectory, Converter={StaticResource BoolToFolderIconConverter}}" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding FileName}" FontWeight="Bold" Background="Transparent" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock Text="{Binding SizeText}" Foreground="#555" Margin="10,0" Grid.Column="1" VerticalAlignment="Center"/>

                        <Button Grid.Column="2" Padding="8,2" Tag="{Binding}" Click="BtnToggleSync_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="⏸ 暂停"/>
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StateText}" Value="✅ 已同步">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                            <Setter Property="Content" Value="▶ 继续"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StateText}" Value="❌ 失败">
                                            <Setter Property="Content" Value="🔄 重试"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <Button Content="📁 选择本地" Click="BtnSelectLocal_Click" Padding="10,5" Grid.Column="0"/>
                <TextBlock x:Name="TxtLocalPath" Text="未选择" VerticalAlignment="Center" Margin="10,0" Foreground="Gray" Grid.Column="1" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                <CheckBox x:Name="ChkEncrypt" Content="🔒 加密同步" IsChecked="True" VerticalAlignment="Center" FontWeight="Bold" Grid.Column="2" Margin="10,0,20,0" Click="ChkEncrypt_Click"/>

                <Button Content="☁️ 绑定云端" Click="BtnSelectRemote_Click" Padding="10,5" Grid.Column="3"/>
                <TextBlock x:Name="TxtRemotePath" Text="未绑定" VerticalAlignment="Center" Margin="10,0" Foreground="Gray" Grid.Column="4" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="本地文件实时同步状态" Grid.Column="0" Background="White">
                <ListBox x:Name="ListLocalSync" ItemTemplate="{StaticResource SyncFileTemplate}" HorizontalContentAlignment="Stretch" BorderThickness="0" MouseDoubleClick="ListLocalSync_MouseDoubleClick"/>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <GroupBox Header="云端同步目录" Grid.Column="2" Background="White">
                <ListBox x:Name="ListRemoteSync" HorizontalContentAlignment="Stretch" BorderThickness="0" MouseDoubleClick="ListRemoteSync_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding IsDirectory, Converter={StaticResource BoolToFolderIconConverter}}"/>
                                <TextBlock Text="{Binding Name}" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="打开/播放" Click="MenuRemoteOpen_Click"/>
                            <MenuItem Header="下载到本地" Click="MenuRemoteDownload_Click"/>
                            <Separator/>
                            <MenuItem Header="新建文件夹" Click="MenuRemoteNewFolder_Click"/>
                            <MenuItem Header="重命名" Click="MenuRemoteRename_Click"/>
                            <Separator/>
                            <MenuItem Header="删除" Foreground="Red" Click="MenuRemoteDelete_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2" Background="White" Padding="10" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <Button Content="⬅ 返回主界面" Click="BtnReturnMain_Click" HorizontalAlignment="Left" Padding="15,5"/>
                <TextBlock x:Name="TxtSyncStatus" Text="等待配置同步目录..." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" FontWeight="Bold"/>
                <Button Content="⏬ 最小化至托盘" Click="BtnMinimizeTray_Click" HorizontalAlignment="Right" Padding="15,5"/>
            </Grid>
        </Border>
    </Grid>
</Window>