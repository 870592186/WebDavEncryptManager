<Window x:Class="WebDavEncryptManager.RemoteFolderSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择云端目录" Height="400" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtCurrentPath" Text="📂 当前路径:" FontWeight="Bold" Grid.Row="0" Margin="0,5,0,10" Background="#F0F0F0" Padding="8"/>

        <ListBox x:Name="ListFolders" Grid.Row="1" MouseDoubleClick="ListFolders_MouseDoubleClick" BorderBrush="#CCC">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" Margin="2,4"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Button Content="➕ 新建文件夹" Click="BtnNewFolder_Click" HorizontalAlignment="Left" Padding="15,6"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Click="BtnCancel_Click" Margin="0,0,10,0" Padding="20,6"/>
                <Button Content="确认选择此目录" Click="BtnSelect_Click" FontWeight="Bold" Padding="20,6" Background="#E3F2FD"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>