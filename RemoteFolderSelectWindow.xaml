<Window x:Class="WebDavEncryptManager.RemoteFolderSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择目标文件夹" Height="400" Width="350" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtCurrentPath" Text="📂 当前路径: /" FontWeight="Bold" Margin="0,0,0,10" Grid.Row="0"/>

        <ListBox x:Name="ListFolders" Grid.Row="1" MouseDoubleClick="ListFolders_MouseDoubleClick" DisplayMemberPath="Name">
            <!-- 仅显示文件夹名称 -->
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" Width="70" Height="28" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="移动到此文件夹" Width="120" Height="28" Background="#0078D7" Foreground="White" Click="BtnSelect_Click"/>
        </StackPanel>
    </Grid>
</Window>