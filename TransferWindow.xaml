<Window x:Class="WebDavEncryptManager.TransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WebDavEncryptManager"
        Title="传输管理列表" Height="500" Width="700" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <DataTemplate x:Key="TaskTemplate">
            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="5,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding FileName}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusText}" Value="❌ 已失效">
                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                        <Setter Property="Foreground" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="{Binding StatusText}" Foreground="Gray" HorizontalAlignment="Right" Grid.Row="0" Grid.Column="1"/>

                    <ProgressBar Value="{Binding Percentage}" Minimum="0" Maximum="100" Height="15" Margin="0,5,0,0" Grid.Row="1" Grid.ColumnSpan="2"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0">

                        <Button Tag="{Binding}" Click="BtnTogglePauseDown_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Margin" Value="5,0,0,0"/>
                                    <Setter Property="Padding" Value="8,2"/>
                                    <Setter Property="Content" Value="⏸ 暂停下载"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsUpload}" Value="False"/>
                                                <Condition Binding="{Binding IsCompleted}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>

                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                            <Setter Property="Content" Value="▶ 继续下载"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding StatusText}" Value="❌ 已失效">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Tag="{Binding}" Click="BtnToggleCancelUp_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Margin" Value="5,0,0,0"/>
                                    <Setter Property="Padding" Value="8,2"/>
                                    <Setter Property="Content" Value="⏹ 取消上传"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsUpload}" Value="True"/>
                                                <Condition Binding="{Binding IsCompleted}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>

                                        <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                                            <Setter Property="Content" Value="🔄 重新上传"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusText}" Value="❌ 上传失败">
                                            <Setter Property="Content" Value="🔄 重新上传"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusText}" Value="❌ 发生异常">
                                            <Setter Property="Content" Value="🔄 重新上传"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding StatusText}" Value="❌ 已失效">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🗑 删除任务" Tag="{Binding}" Click="BtnItemDelete_Click" Margin="5,0,0,0" Padding="8,2" Foreground="Red"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <TabControl x:Name="Tabs">
            <TabItem Header="⬇️ 下载列表">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="5" Background="#F9F9F9">
                        <Button Content="全部暂停下载" Click="BtnAllPauseDown_Click" Margin="5" Padding="8,3"/>
                        <Button Content="全部继续下载" Click="BtnAllResumeDown_Click" Margin="5" Padding="8,3"/>
                        <Button Content="清空失效任务" Click="BtnClearFailed_Click" Margin="5" Padding="8,3"/>
                        <Button Content="清空已完成" Click="BtnClearCompleted_Click" Margin="5" Padding="8,3"/>
                    </WrapPanel>
                    <ListBox x:Name="ListDownloads" Grid.Row="1" ItemTemplate="{StaticResource TaskTemplate}" HorizontalContentAlignment="Stretch" BorderThickness="0"/>
                </Grid>
            </TabItem>

            <TabItem Header="⬆️ 上传列表">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="5" Background="#F9F9F9">
                        <Button Content="全部取消上传" Click="BtnAllCancelUp_Click" Margin="5" Padding="8,3"/>
                        <Button Content="全部重新上传" Click="BtnAllRetryUp_Click" Margin="5" Padding="8,3"/>
                        <Button Content="清空失效任务" Click="BtnClearFailed_Click" Margin="5" Padding="8,3"/>
                        <Button Content="清空已完成" Click="BtnClearCompleted_Click" Margin="5" Padding="8,3"/>
                    </WrapPanel>
                    <ListBox x:Name="ListUploads" Grid.Row="1" ItemTemplate="{StaticResource TaskTemplate}" HorizontalContentAlignment="Stretch" BorderThickness="0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>