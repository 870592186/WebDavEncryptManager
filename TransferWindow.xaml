<Window x:Class="WebDavEncryptManager.TransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="传输管理列表" Height="450" Width="600" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- 定义任务列表的统一显示样式 -->
        <DataTemplate x:Key="TaskTemplate">
            <Grid Margin="5,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding FileName}" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                <TextBlock Text="{Binding StatusText}" Foreground="Gray" HorizontalAlignment="Right" Grid.Row="0" Grid.Column="1"/>

                <ProgressBar Value="{Binding Percentage}" Minimum="0" Maximum="100" Height="15" Margin="0,5,0,0" Grid.Row="1" Grid.ColumnSpan="2"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <TabControl x:Name="Tabs">
            <TabItem Header="⬇️ 下载列表">
                <ListBox x:Name="ListDownloads" ItemTemplate="{StaticResource TaskTemplate}" HorizontalContentAlignment="Stretch" BorderThickness="0"/>
            </TabItem>
            <TabItem Header="⬆️ 上传列表">
                <ListBox x:Name="ListUploads" ItemTemplate="{StaticResource TaskTemplate}" HorizontalContentAlignment="Stretch" BorderThickness="0"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>